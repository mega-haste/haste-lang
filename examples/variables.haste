# Variables in haste 

func main() {
	# using `let` and `mut` after it you can define a mutable variable that we can change it's value.
	let mut age: uint = 17;
	age++;

	# All variables in haste are immutable, which means that you cannot change the value after initializing
	let name: string = "Hesham";
	name = "Jack"; # Nuh uh
}
